# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://ybgtzyutbvwfhgtlmnah.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# DB connection string — used by migration list and local scripts.
# Format: postgresql://postgres:<db-password>@db.ybgtzyutbvwfhgtlmnah.supabase.co:6543/postgres
DATABASE_URL=<your-database-url>

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at console.cloud.google.com — set ONLY after registering the exact
# redirect URI: https://ybgtzyutbvwfhgtlmnah.supabase.co/functions/v1/google-oauth-callback
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── Edge Function Secrets (set in Supabase Vault, not here) ─────────────────
# These are stored in Supabase Vault and accessed via Deno.env.get() in edge
# functions. Do NOT put them here — this is documentation only.
#
# GOOGLE_CLIENT_ID      — same as above, set in Vault for edge functions
# GOOGLE_CLIENT_SECRET  — same as above, set in Vault for edge functions
# SUPABASE_SERVICE_ROLE_KEY — auto-available in edge functions, no Vault needed
# CRON_SECRET           — a random secret used to authenticate Cron → edge fn calls
