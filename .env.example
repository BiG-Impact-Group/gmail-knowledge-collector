# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://ybgtzyutbvwfhgtlmnah.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# DB connection string — used by migration list and local scripts.
# Format: postgresql://postgres:<db-password>@db.ybgtzyutbvwfhgtlmnah.supabase.co:6543/postgres
DATABASE_URL=<your-database-url>

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at console.cloud.google.com — set ONLY after registering the exact
# redirect URI: https://ybgtzyutbvwfhgtlmnah.supabase.co/functions/v1/google-oauth-callback
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── Edge Function Secrets (set via `supabase secrets set`, not here) ─────────
# Accessed in edge functions via Deno.env.get(). Never commit real values.
#
# GOOGLE_CLIENT_ID      — from Google Cloud Console OAuth credentials
# GOOGLE_CLIENT_SECRET  — from Google Cloud Console OAuth credentials
# STATE_SECRET          — auto-generated; already set
# CRON_SECRET           — auto-generated; already set
# SITE_URL              — https://knowledgecollector.netlify.app (already set)
# SUPABASE_SERVICE_ROLE_KEY — auto-available in edge functions, no Vault needed
